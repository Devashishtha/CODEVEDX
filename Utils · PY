def get_float_input(prompt, min_val=None, max_val=None):
    """
    Prompt user for a float input with validation.

    Args:
        prompt: string to display
        min_val: minimum acceptable value (optional)
        max_val: maximum acceptable value (optional)

    Returns:
        validated float value
    """
    while True:
        try:
            value = float(input(prompt))
            if min_val is not None and value < min_val:
                print(f"  ❌ Value must be at least {min_val}. Try again.")
                continue
            if max_val is not None and value > max_val:
                print(f"  ❌ Value must be at most {max_val}. Try again.")
                continue
            return value
        except ValueError:
            print("  ❌ Invalid input. Please enter a number.")


def get_month_input(prompt):
    """
    Prompt user for a month in YYYY-MM format with validation.

    Args:
        prompt: string to display

    Returns:
        validated month string in YYYY-MM format
    """
    while True:
        value = input(prompt).strip()
        if re.match(r"^\d{4}-(0[1-9]|1[0-2])$", value):
            return value
        print("  ❌ Invalid format. Use YYYY-MM (e.g. 2024-05).")
